// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int       @id @default(autoincrement())
  authProvider    String    @map("auth_provider")
  providerId      String    @map("provider_id")
  nickname        String    @unique
  refreshToken    String?   @map("refresh_token")
  avatarColor     String    @default("#ff2d87") @map("avatar_color")
  profileImageKey String?   @map("profile_image_key")
  streak          Int       @default(0)
  wins            Int       @default(0)
  losses          Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  termsVersion    String?   @map("terms_version")
  privacyVersion  String?   @map("privacy_version")
  consentedAt     DateTime? @map("consented_at")

  soloRecords     SoloRecord[]
  diaryRecords    DiaryRecord[]

  @@unique([authProvider, providerId])
}

model SoloRecord {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  peakDb    Float
  bestDb    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model DiaryRecord {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  peakDb    Float
  emoji     String
  comment   String?
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([userId, date])
}
