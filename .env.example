DATABASE_URL="postgresql://deci_duel:deci1234@localhost:5432/deci_duel"

PORT=3000

JWT_SECRET="change-me"

# ─── CORS (Admin SPA 등 브라우저 클라이언트, 2026-06-08 추가) ────────
# 브라우저에서 직접 fetch로 호출하는 클라이언트(Admin SPA 등)의 허용 오리진 목록.
# 콤마(,)로 여러 값 등록 가능. 미설정 시 로컬 Admin SPA dev 서버(http://localhost:5173)만 허용.
# 운영 배포 시 Cloudflare Pages 등 실제 배포 도메인을 반드시 추가하세요.
# 예: CORS_ALLOWED_ORIGINS="http://localhost:5173,https://admin.deciduel.app"
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ─── Logging (pino, 2026-06-07 추가) ────────────────────────────────
# 로그 레벨 (trace|debug|info|warn|error|fatal). 미설정 시 production=info, 그 외=debug.
LOG_LEVEL="info"
# 콘솔 출력을 pino-pretty로 보기 좋게 포맷할지 여부. 미설정 시 production이 아니면 자동 on.
# 운영(JSON 수집기로 적재)에서는 반드시 "false"로 설정하세요.
LOG_PRETTY="false"

# ─── Cloudflare R2 (이미지 업로드/저장) ─────────────────────────────
# 프로필 이미지 등 파일 업로드에 사용하는 Cloudflare R2(S3 호환) 버킷 자격 증명.
# accountId가 비어 있으면 R2StorageService가 비활성 상태로 동작합니다 (업로드 시 에러).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# ─── OAuth (네이티브 SDK 기준, 2026-06-07 전환) ──────────────────────
# 앱이 Apple/Google/Kakao 네이티브 SDK로 idToken/accessToken을 직접 발급받아
# POST /auth/oauth { provider, idToken? , accessToken? }로 전달합니다.
# 서버는 issuer 검증 + 아래 audience 허용 목록으로 token을 검증합니다.
#
# 값을 비워두면 audience 검증을 스킵합니다 (로컬 개발 한정 — 운영 배포 전 반드시 설정).
# 운영/preview에서는 true 권장. true이거나 NODE_ENV=production이면 allowlist 누락 시 인증 실패.
OAUTH_AUDIENCE_REQUIRED="true"

# Apple: Sign in with Apple의 audience(aud)는 앱의 Bundle Identifier 입니다.
# 콤마로 여러 값 등록 가능 (예: 추후 다른 플랫폼 클라이언트 추가 시)
APPLE_ALLOWED_AUDIENCES="com.deciduel.app"

# Google: 네이티브 SDK(@react-native-google-signin/google-signin)는
# GoogleSignin.configure({ webClientId })에 설정한 Web Client ID를 idToken의 audience로 발급합니다.
# iOS/Android 클라이언트 ID는 audience로 오지 않을 수 있으나, 안전하게 모두 허용 목록에 등록합니다 (콤마 구분).
GOOGLE_ALLOWED_CLIENT_IDS="<WEB_CLIENT_ID>.apps.googleusercontent.com,<IOS_CLIENT_ID>.apps.googleusercontent.com,<ANDROID_CLIENT_ID>.apps.googleusercontent.com"

# Kakao: 네이티브 SDK가 발급한 accessToken을 Kakao REST API(/v2/user/me)로 검증합니다.
# REST API 키/시크릿은 서버 검증에 필요하지 않습니다 (accessToken은 Bearer로 그대로 전달).

# ─── Admin (Phase 2 MVP, 2026-06-07 추가) ──────────────────────────
# 관리자 전용 API(/admin/*)는 일반 유저 인증과 완전히 분리된 별도 시스템입니다.
# 절대 코드/시크릿 원문을 로그/저장소에 남기지 마세요. 운영 배포 전 반드시 강력한 값으로 교체하세요.

# 관리자 로그인 접속 코드 (POST /admin/auth/login). 충분히 길고 예측 불가능한 값을 사용하세요.
# 미설정 시 모든 로그인 시도가 401로 거부됩니다.
ADMIN_ACCESS_CODE="change-me-admin-access-code"

# Admin JWT 서명용 secret. 일반 유저 JWT_SECRET과 반드시 다른 값을 사용하세요.
# fail-closed: 아래 중 하나라도 해당하면 서버가 즉시 기동에 실패합니다 (절대 안전하지
# 않은 기본값으로 동작하지 않음) — ① 미설정/빈 값  ② 플레이스홀더 값 그대로  ③ JWT_SECRET과 동일.
# 반드시 충분히 길고 무작위적인, JWT_SECRET과 다른 값으로 교체하세요.
# (예시 값 "change-me-admin-secret"은 코드에 하드코딩된 플레이스홀더 검증 문자열과
#  동일하게 맞춰뒀습니다 — 교체하지 않고 그대로 복사해 쓰면 서버가 기동 자체를 거부합니다)
ADMIN_JWT_SECRET="change-me-admin-secret"

# Admin JWT 만료 시간 (초 단위). 미설정/숫자 변환 실패 시 기본 3600(1시간) 사용.
ADMIN_TOKEN_EXPIRES_IN="3600"

# 카카오 ID 비교
KAKAO_APP_ID="123456"
